# -----------------------------------------------------------------------------
# UGREEN NAS Lyrics Downloader 1.0.0
# Copyright (c) 2026 Roman Glos
# Deutsch: Einstellungen für den automatischen Lyrics-Download.
# English: Settings for automatic lyrics download.
# -----------------------------------------------------------------------------

# Deutsch: Host-Pfad zu deiner Musikbibliothek auf dem NAS.
# English: Host path to your music library on the NAS.
HOST_MUSIC_DIR=/volume1/Emby/Musik

# Deutsch: Benutzer/Gruppen-ID für Dateizugriff. Bei Bedarf an deinen NAS-Benutzer anpassen.
# English: User/group ID for file access. Adjust to your NAS user if required.
PUID=1000
PGID=10

# Deutsch: Scan-Modus. 0 = einmal ausführen und beenden. 86400 = einmal täglich im Container laufen lassen.
# English: Scan mode. 0 = run once and exit. 86400 = keep container running and scan once per day.
SCAN_INTERVAL_SECONDS=0

# Deutsch: Unterstützte Audiodateien.
# English: Supported audio files.
AUDIO_EXTENSIONS=.mp3,.flac,.m4a,.mp4,.ogg,.opus

# Deutsch: Nur echte synchronisierte LRC-Lyrics schreiben. Empfohlen für den UGREEN-Musik-Test.
# English: Only write real synchronized LRC lyrics. Recommended for the UGREEN Music test.
REQUIRE_SYNCED_LYRICS=true

# Deutsch: Wenn keine synchronisierten Lyrics gefunden werden, unsynchronisierte Lyrics als einfache LRC-Datei schreiben.
# English: If no synced lyrics are found, write unsynced lyrics as a simple LRC file.
WRITE_PLAIN_AS_LRC=false

# Deutsch: LRC-Datei neben der Musikdatei speichern, z. B. Song.mp3 -> Song.lrc.
# English: Save LRC file next to the audio file, e.g. Song.mp3 -> Song.lrc.
WRITE_SIDECAR_LRC=true

# Deutsch: Lyrics zusätzlich in die Audiodatei-Tags schreiben. Für den UGREEN-Test normalerweise nicht nötig.
# English: Also write lyrics into audio file tags. Usually not needed for the UGREEN test.
WRITE_EMBEDDED_TAGS=false

# Deutsch: Vorhandene .lrc-Dateien nicht überschreiben.
# English: Do not overwrite existing .lrc files.
SKIP_EXISTING_LRC=true

# Deutsch: Audiodatei nach erfolgreichem Schreiben kurz anfassen, damit UGOS/UGREEN Music die Änderung eher erkennt.
# English: Touch audio file after successful write so UGOS/UGREEN Music is more likely to detect the change.
TOUCH_AUDIO_ON_WRITE=true

# Deutsch: Testlauf ohne Dateischreibzugriff.
# English: Dry run without writing files.
DRY_RUN=false

# Deutsch: Sekunden Pause zwischen API-Anfragen. Bitte fair nutzen.
# English: Seconds to wait between API requests. Please use fairly.
REQUEST_DELAY_SECONDS=1.0

# Deutsch: Maximale Anzahl Dateien pro Lauf. 0 = keine Begrenzung.
# English: Maximum files per run. 0 = unlimited.
MAX_FILES_PER_RUN=0

# Deutsch: Bericht speichern.
# English: Save report.
SAVE_REPORT=true
REPORT_PATH=/reports/last_report.json

# Deutsch: Log-Level: DEBUG, INFO, WARNING, ERROR.
# English: Log level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Deutsch: User-Agent für LRCLIB.
# English: User agent for LRCLIB.
USER_AGENT=UGREEN-NAS-Lyrics-Downloader/1.0.0 (Roman-Glos)
